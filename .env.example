# ── Povinné ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# Qdrant Cloud (odporúčané)
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Alebo Qdrant Local Docker:
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# ── API kľúče prístupových úrovní ──────────────────────────
# Vygeneruj náhodné stringy: python3 -c "import secrets; print(secrets.token_hex(24))"
MENTOR_BOT_API_KEY=your-mentor-bot-key-here       # public_only
INTERNAL_TOOLS_API_KEY=your-internal-tools-key    # public + internal
ADMIN_API_KEY=your-admin-key-here                 # full (všetko vrátane private)

# Token na ochranu MCP SSE endpointu (voliteľné)
MCP_SECRET_TOKEN=your-mcp-secret-token

# ── Voliteľné — reranker (VÝRAZNE zlepší kvalitu) ──────────
# Trial key zadarmo: https://dashboard.cohere.com/welcome/register
COHERE_API_KEY=

# ── Voliteľné — query expansion (HyDE / multi-query) ───────
# Zapne opt-in expansion cez Claude Haiku
ANTHROPIC_API_KEY=
